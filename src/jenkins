}pipeline {
    agent any

    tools {
        maven 'Maven3.9'   // Name configured in Jenkins Global Tools
        jdk 'JDK-17'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/naveen-nani66/Practice-repo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
    }

    post {
        success {
            echo 'Build Successful 🎉'
        }
        failure {
            echo 'Build Failed ❌'
        }
    }
}
